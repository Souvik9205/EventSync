generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  password           String
  name               String?
  imgURL             String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  events             Event[]              @relation("UserEvents")
  PasswordResetToken PasswordResetToken[]
  eventsOwned        Event[]              @relation("EventOwnership")
}

model Event {
  id             String        @id @default(cuid())
  name           String
  description    String
  tickets        Int?
  price          Int           @default(0)
  organization   String
  orgImgURL      String
  dateTime       DateTime
  location       String
  createdById    String
  additionalData String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  attendees      Attendance[]
  customFields   CustomField[]
  createdBy      User          @relation("UserEvents", fields: [createdById], references: [id])
  review         Review?
  admins         User[]        @relation("EventOwnership")
}

model CustomField {
  id        String @id @default(cuid())
  eventId   String
  fieldName String
  fieldType String
  Event     Event  @relation(fields: [eventId], references: [id])
}

model Attendance {
  id        String   @id @default(cuid())
  user      String
  eventId   String
  timestamp DateTime @default(now())
  fields    Json
  verified  Boolean
  Event     Event    @relation(fields: [eventId], references: [id])
}

model Review {
  id           String  @id @default(cuid())
  eventId      String  @unique
  participants Int
  Review       Decimal
  Event        Event   @relation(fields: [eventId], references: [id])
}

model Otp {
  id        String   @id @default(cuid())
  user      String
  otp       String
  data      Json
  type      OTP_Type
  expiresAt DateTime
}

model PasswordResetToken {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])
}

enum OTP_Type {
  UserOtp
  EverntOtp
  RegisterOtp
}
